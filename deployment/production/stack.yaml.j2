networks:
  network:
    driver: overlay

secrets:
  {{ __db_password__ }}:
    external: true
  {{ __minio_password__ }}:
    external: true
  {{ __rabbitmq_password__ }}:
    external: true
  {{ __redis_password__ }}:
    external: true
  {{ __root_password__ }}:
    external: true

services:
  alloy:
    command:
      - run
      - --server.http.listen-addr=0.0.0.0:12345
      - --storage.path=/var/lib/alloy/data
      - /etc/alloy/config.alloy
    deploy:
      labels:
        - traefik.enable=true
        - traefik.http.middlewares.alloy-ratelimit.ratelimit.average={{ alloy.ratelimit_average }}
        - traefik.http.middlewares.alloy-ratelimit.ratelimit.burst={{ alloy.ratelimit_burst }}
        - traefik.http.routers.alloy.rule=Host(`alloy.{{ global.domain }}`) && Path(`/collect`)
        {% if global.tls == "true" %}
        - traefik.http.routers.alloy.entrypoints=websecure
        - traefik.http.routers.alloy.tls=true
        {% else %}
        - traefik.http.routers.alloy.entrypoints=web
        - traefik.http.routers.alloy.tls=false
        {% endif %}
        - traefik.http.routers.alloy.middlewares=alloy-ratelimit
        - traefik.http.services.alloy.loadbalancer.server.port=12347
      mode: global
      resources:
        limits:
          cpus: {{ alloy.cpus }}
          memory: {{ alloy.memory_limit }}
        reservations:
          cpus: {{ alloy.cpus_reservation }}
          memory: {{ alloy.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
    healthcheck:
      test:
        - CMD-SHELL
        - timeout 3 bash -c '</dev/tcp/localhost/12345' && echo "OK" || exit 1
      timeout: 5s
      interval: 15s
      retries: 5
      start_period: 10s
    image: grafana/alloy:v1.9.2
    networks:
      network:
    volumes:
      - type: bind
        source: /var/run/docker.sock
        target: /var/run/docker.sock
      - type: bind
        source: {{ __volumes_path__ }}/alloy/config.alloy
        target: /etc/alloy/config.alloy

  api:
    deploy:
      labels:
        - traefik.enable=true
        - traefik.http.middlewares.api-ratelimit.ratelimit.average={{ api.ratelimit_average }}
        - traefik.http.middlewares.api-ratelimit.ratelimit.burst={{ api.ratelimit_burst }}
        - traefik.http.routers.api.rule=Host(`api.{{ global.domain }}`) && !PathRegexp(`^/v[0-9]+/sso`) && !PathPrefix(`/actuator`) && !PathPrefix(`/metrics`)
        {% if global.tls == "true" %}
        - traefik.http.routers.api.entrypoints=websecure
        - traefik.http.routers.api.tls=true
        {% else %}
        - traefik.http.routers.api.entrypoints=web
        - traefik.http.routers.api.tls=false
        {% endif %}
        - traefik.http.routers.api.middlewares=api-ratelimit
        - traefik.http.routers.api.service=api
        - traefik.http.routers.ws.rule=Host(`ws.{{ global.domain }}`)
        {% if global.tls == "true" %}
        - traefik.http.routers.ws.entrypoints=websecure
        - traefik.http.routers.ws.tls=true
        {% else %}
        - traefik.http.routers.ws.entrypoints=web
        - traefik.http.routers.ws.tls=false
        {% endif %}
        - traefik.http.routers.ws.middlewares=api-ratelimit
        - traefik.http.routers.ws.service=ws
        - traefik.http.services.api.loadbalancer.server.port=8080
        - traefik.http.services.ws.loadbalancer.server.port=8081
        - traefik.http.services.ws.loadbalancer.sticky.cookie=true
        - traefik.http.services.ws.loadbalancer.sticky.cookie.name=ws-session
        {% if global.tls == "true" %}
        - traefik.http.services.ws.loadbalancer.sticky.cookie.secure=true
        - traefik.http.services.ws.loadbalancer.sticky.cookie.samesite=none
        {% else %}
        - traefik.http.services.ws.loadbalancer.sticky.cookie.secure=false
        - traefik.http.services.ws.loadbalancer.sticky.cookie.samesite=lax
        {% endif %}
        - traefik.http.services.ws.loadbalancer.sticky.cookie.httponly=true
      mode: replicated
      replicas: {{ api.replicas }}
      resources:
        limits:
          cpus: {{ api.cpus }}
          memory: {{ api.memory_limit }}
        reservations:
          cpus: {{ api.cpus_reservation }}
          memory: {{ api.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
      update_config:
        order: start-first
    environment:
      {% if global.tls == "true" %}
      COOKIE_DOMAIN: .{{ global.domain }}
      COOKIE_SECURE: "true"
      {% else %}
      COOKIE_SECURE: "false"
      {% endif %}
      CLAMAV_HOST: clamav
      CLAMAV_PORT: 3310
      DB_PASSWORD_FILE: /run/secrets/db_password
      DB_URL: jdbc:postgresql://postgres:5432/forseti
      DB_USER: forseti
      {% if global.tls == "true" %}
      GRAFANA_PUBLIC_URL: https://grafana.{{ global.domain }}
      {% else %}
      GRAFANA_PUBLIC_URL: http://grafana.{{ global.domain }}
      {% endif %}
      JAVA_TOOL_OPTIONS: "-XX:MaxRAMPercentage=80.0 -XX:InitialRAMPercentage=50.0 -XX:MinRAMPercentage=30.0"
      SESSION_EXPIRATION: {{ session.expiration }}
      SESSION_ROOT_EXPIRATION: {{ session.root_expiration }}
      SESSION_SYSTEM_EXPIRATION: {{ session.system_expiration }}
      MINIO_ENDPOINT: http://minio:9000
      MINIO_ACCESS_KEY: forseti
      MINIO_SECRET_KEY_FILE: /run/secrets/minio_password
      MINIO_BUCKET: forseti
      RABBITMQ_HOST: rabbitmq
      RABBITMQ_PORT: 5672
      RABBITMQ_USER: forseti
      RABBITMQ_PASSWORD_FILE: /run/secrets/rabbitmq_password
      RABBITMQ_VHOST: /
      RABBITMQ_SUBMISSION_QUEUE: submission-queue
      RABBITMQ_SUBMISSION_EXCHANGE: submission-exchange
      RABBITMQ_SUBMISSION_ROUTING_KEY: submission-routing-key
      RABBITMQ_SUBMISSION_FAILED_QUEUE: submission-failed-queue
      RABBITMQ_WEBSOCKET_EXCHANGE: websocket-exchange
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD_FILE: /run/secrets/redis_password
      ROOT_PASSWORD_FILE: /run/secrets/root_password
      OTEL_EXPORTER_OTLP_TRACES_ENDPOINT: http://alloy:4317
      OTEL_EXPORTER_OTLP_PROTOCOL: grpc
      OTEL_LOGS_EXPORTER: none
      OTEL_METRICS_EXPORTER: none
      OTEL_SERVICE_NAME: api
      SPRING_PROFILES_ACTIVE: production
      VERSION: {{ __version__ }}
      {% if global.tls == "true" %}
      WEBAPP_PUBLIC_URL: https://{{ global.domain }}
      {% else %}
      WEBAPP_PUBLIC_URL: http://{{ global.domain }}
      {% endif %}
    healthcheck:
      test:
        - CMD-SHELL
        - curl -f http://localhost:8080/actuator/health
      timeout: 10s
      interval: 30s
      retries: 5
      start_period: 60s
    image: leonfoliveira/forseti-api:{{ __version__ }}
    networks:
      network:
    secrets:
      - source: {{ __db_password__ }}
        target: db_password
      - source: {{ __minio_password__ }}
        target: minio_password
      - source: {{ __rabbitmq_password__ }}
        target: rabbitmq_password
      - source: {{ __redis_password__ }}
        target: redis_password
      - source: {{ __root_password__ }}
        target: root_password

  autojudge:
    deploy:
      mode: replicated
      replicas: 0
      resources:
        limits:
          cpus: {{ autojudge.cpus }}
          memory: {{ autojudge.memory_limit }}
        reservations:
          cpus: {{ autojudge.cpus_reservation }}
          memory: {{ autojudge.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
      update_config:
        order: start-first
    environment:
      API_URL: http://api:8080
      DB_PASSWORD_FILE: /run/secrets/db_password
      DB_URL: jdbc:postgresql://postgres:5432/forseti
      DB_USER: forseti
      CLAMAV_HOST: clamav
      CLAMAV_PORT: 3310
      JAVA_TOOL_OPTIONS: "-XX:MaxRAMPercentage=80.0 -XX:InitialRAMPercentage=50.0 -XX:MinRAMPercentage=30.0"
      SESSION_EXPIRATION: {{ session.expiration }}
      SESSION_ROOT_EXPIRATION: {{ session.root_expiration }}
      SESSION_SYSTEM_EXPIRATION: {{ session.system_expiration }}
      MAX_CONCURRENT_SUBMISSIONS: {{ autojudge.max_concurrent_submissions }}
      MINIO_ENDPOINT: http://minio:9000
      MINIO_ACCESS_KEY: forseti
      MINIO_SECRET_KEY_FILE: /run/secrets/minio_password
      MINIO_BUCKET: forseti
      RABBITMQ_HOST: rabbitmq
      RABBITMQ_PORT: 5672
      RABBITMQ_USER: forseti
      RABBITMQ_PASSWORD_FILE: /run/secrets/rabbitmq_password
      RABBITMQ_VHOST: /
      RABBITMQ_SUBMISSION_QUEUE: submission-queue
      RABBITMQ_SUBMISSION_EXCHANGE: submission-exchange
      RABBITMQ_SUBMISSION_ROUTING_KEY: submission-routing-key
      RABBITMQ_SUBMISSION_FAILED_QUEUE: submission-failed-queue
      RABBITMQ_WEBSOCKET_EXCHANGE: websocket-exchange
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD_FILE: /run/secrets/redis_password
      ROOT_PASSWORD_FILE: /run/secrets/root_password
      OTEL_EXPORTER_OTLP_TRACES_ENDPOINT: http://alloy:4317
      OTEL_EXPORTER_OTLP_PROTOCOL: grpc
      OTEL_LOGS_EXPORTER: none
      OTEL_METRICS_EXPORTER: none
      OTEL_SERVICE_NAME: autojudge
      SPRING_PROFILES_ACTIVE: production
      VERSION: {{ __version__ }}
    healthcheck:
      test:
        - CMD-SHELL
        - curl -f http://localhost:8082/actuator/health
      timeout: 10s
      interval: 30s
      retries: 5
      start_period: 60s
    image: leonfoliveira/forseti-autojudge:{{ __version__ }}
    networks:
      network:
    volumes:
      - type: bind
        source: /var/run/docker.sock
        target: /var/run/docker.sock
      - type: bind
        source: /tmp
        target: /tmp
    secrets:
      - source: {{ __db_password__ }}
        target: db_password
      - source: {{ __minio_password__ }}
        target: minio_password
      - source: {{ __rabbitmq_password__ }}
        target: rabbitmq_password
      - source: {{ __redis_password__ }}
        target: redis_password
      - source: {{ __root_password__ }}
        target: root_password

  autojudge-autoscaler:
    deploy:
      mode: replicated
      replicas: 1
      resources:
        limits:
          cpus: {{ autojudge_autoscaler.cpus }}
          memory: {{ autojudge_autoscaler.memory_limit }}
        reservations:
          cpus: {{ autojudge_autoscaler.cpus_reservation }}
          memory: {{ autojudge_autoscaler.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
    environment:
      COOLDOWN: {{ autojudge_autoscaler.cooldown }}
      INTERVAL: {{ autojudge_autoscaler.interval }}
      MESSAGES_PER_REPLICA: {{ autojudge_autoscaler.messages_per_replica }}
      MAX_REPLICAS: {{ autojudge_autoscaler.max_replicas }}
      MIN_REPLICAS: {{ autojudge_autoscaler.min_replicas }}
      QUEUE_NAME: submission-queue
      RABBITMQ_HOST: rabbitmq
      RABBITMQ_PORT: 15672
      RABBITMQ_USER: forseti
      RABBITMQ_PASSWORD_FILE: /run/secrets/rabbitmq_password
      RABBITMQ_VHOST: /
      SERVICE_NAME: forseti_autojudge
    healthcheck:
      test:
        - CMD-SHELL
        - curl -f http://localhost:7000/health
      timeout: 10s
      interval: 30s
      retries: 5
      start_period: 60s
    image: leonfoliveira/forseti-autoscaler:{{ __version__ }}
    networks:
      network:
    volumes:
      - type: bind
        source: /var/run/docker.sock
        target: /var/run/docker.sock
    secrets:
      - source: {{ __rabbitmq_password__ }}
        target: rabbitmq_password

  cadvisor:
    deploy:
      mode: global
      resources:
        limits:
          cpus: {{ cadvisor.cpus }}
          memory: {{ cadvisor.memory_limit }}
        reservations:
          cpus: {{ cadvisor.cpus_reservation }}
          memory: {{ cadvisor.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
    healthcheck:
      test:
        - CMD-SHELL
        - wget --spider -q http://localhost:8080/healthz
      timeout: 5s
      interval: 15s
      retries: 5
      start_period: 10s
    image: gcr.io/cadvisor/cadvisor:v0.49.1
    networks:
      network:
    volumes:
      - type: bind
        source: /
        target: /rootfs
        read_only: true
      - type: bind
        source: /var/run
        target: /var/run
        read_only: true
      - type: bind
        source: /sys
        target: /sys
        read_only: true
      - type: bind
        source: /var/lib/docker
        target: /var/lib/docker
        read_only: true
    
  clamav:
    deploy:
      mode: replicated
      replicas: 1
      resources:
        limits:
          cpus: {{ clamav.cpus }}
          memory: {{ clamav.memory_limit }}
        reservations:
          cpus: {{ clamav.cpus_reservation }}
          memory: {{ clamav.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
    healthcheck:
      test: ["CMD-SHELL", "echo 'PING' | nc -w 5 localhost 3310"]
      timeout: 5s
      interval: 15s
      retries: 5
      start_period: 5s
    image: clamav/clamav:1.5.2
    networks:
      network:
    volumes:
      - type: bind
        source: {{ __volumes_path__ }}/clamd.conf
        target: /etc/clamav/clamd.conf
        read_only: true
      - type: bind
        source: {{ __volumes_path__ }}/freshclam.conf
        target: /etc/clamav/freshclam.conf
        volume: {}
      - type: bind
        source: {{ __volumes_path__ }}/clamav/db
        target: /var/lib/clamav
        read_only: true

  grafana:
    deploy:
      labels:
        - traefik.enable=true
        - traefik.http.middlewares.grafana-ratelimit.ratelimit.average={{ grafana.ratelimit_average }}
        - traefik.http.middlewares.grafana-ratelimit.ratelimit.burst={{ grafana.ratelimit_burst }}
        - traefik.http.middlewares.grafana-auth.forwardauth.address=http://api:8080/v1/sso/grafana
        - traefik.http.middlewares.grafana-auth.forwardauth.authResponseHeaders=X-WEBAUTH-USER,X-WEBAUTH-NAME
        - traefik.http.middlewares.grafana-auth.forwardauth.authRequestHeaders=Cookie
        - traefik.http.routers.grafana.rule=Host(`grafana.{{ global.domain }}`)
        {% if global.tls == "true" %}
        - traefik.http.routers.grafana.entrypoints=websecure
        - traefik.http.routers.grafana.tls=true
        {% else %}
        - traefik.http.routers.grafana.entrypoints=web
        - traefik.http.routers.grafana.tls=false
        {% endif %}
        - traefik.http.routers.grafana.middlewares=grafana-ratelimit,grafana-auth
        - traefik.http.services.grafana.loadbalancer.server.port=3000
      mode: replicated
      replicas: 1
      resources:
        limits:
          cpus: {{ grafana.cpus }}
          memory: {{ grafana.memory_limit }}
        reservations:
          cpus: {{ grafana.cpus_reservation }}
          memory: {{ grafana.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
    entrypoint: sh -c "export DB_PASSWORD=$$(cat /run/secrets/db_password) && /run.sh"
    environment:
      DB_URL: postgres:5432
      DB_NAME: forseti
      DB_USER: forseti
      DB_PASSWORD_FILE: /run/secrets/db_password
      GF_SERVER_DOMAIN: grafana.{{ global.domain }}
      {% if global.tls == "true" %}
      GF_SERVER_ROOT_URL: https://grafana.{{ global.domain }}/
      {% else %}
      GF_SERVER_ROOT_URL: http://grafana.{{ global.domain }}/
      {% endif %}
      GF_USERS_AUTO_ASSIGN_ORG: "true"
      GF_USERS_AUTO_ASSIGN_ORG_ID: "1"
      GF_USERS_AUTO_ASSIGN_ORG_ROLE: Editor
      GF_SECURITY_ADMIN_USER: root
      GF_SECURITY_ADMIN_PASSWORD__FILE: /run/secrets/root_password
      LOKI_URL: http://loki:3100
      PROMETHEUS_URL: http://prometheus:9090
      TEMPO_URL: http://tempo:3200
    healthcheck:
      test:
        - CMD-SHELL
        - curl -f http://localhost:3000/api/health
      timeout: 5s
      interval: 15s
      retries: 5
      start_period: 10s
    image: grafana/grafana-oss:12.0.2
    networks:
      network:
    secrets:
      - source: {{ __db_password__ }}
        target: db_password
      - source: {{ __root_password__ }}
        target: root_password
    volumes:
      - type: volume
        source: grafana_data
        target: /var/lib/grafana
        volume: {}
      - type: bind
        source: {{ __volumes_path__ }}/grafana/grafana.ini
        target: /etc/grafana/grafana.ini
      - type: bind
        source: {{ __volumes_path__ }}/grafana/provisioning/datasources
        target: /etc/grafana/provisioning/datasources
      - type: bind
        source: {{ __volumes_path__ }}/grafana/provisioning/dashboards
        target: /etc/grafana/provisioning/dashboards

  loki:
    deploy:
      mode: replicated
      replicas: 1
      resources:
        limits:
          cpus: {{ loki.cpus }}
          memory: {{ loki.memory_limit }}
        reservations:
          cpus: {{ loki.cpus_reservation }}
          memory: {{ loki.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
    healthcheck:
      test:
        - CMD-SHELL
        - wget --spider -q http://localhost:3100/ready
      timeout: 5s
      interval: 15s
      retries: 5
      start_period: 10s
    entrypoint: /entrypoint.sh
    environment:
      MINIO_ACCESS_KEY: forseti
      MINIO_SECRET_KEY_FILE: /run/secrets/minio_password
      MINIO_BUCKET: forseti-loki
    image: grafana/loki:3.4.4
    networks:
      network:
    volumes:
      - type: bind
        source: {{ __volumes_path__ }}/loki/entrypoint.sh
        target: /entrypoint.sh
        read_only: true
      - type: bind
        source: {{ __volumes_path__ }}/loki/config.yaml
        target: /etc/loki/config.yaml
        read_only: true
      - type: volume
        source: loki_data
        target: /loki
        volume: {}
    secrets:
      - source: {{ __minio_password__ }}
        target: minio_password

  migration:
    deploy:
      labels:
        - type=job
      mode: replicated
      replicas: 1
      resources:
        limits:
          cpus: {{ migration.cpus }}
          memory: {{ migration.memory_limit }}
        reservations:
          cpus: {{ migration.cpus_reservation }}
          memory: {{ migration.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
    entrypoint: sh -c "flyway -url=$${FLYWAY_URL} -user=$${FLYWAY_USER} -password=$$(cat /run/secrets/db_password) -connectRetries=60 -connectRetriesInterval=5 migrate"
    environment:
      FLYWAY_URL: jdbc:postgresql://postgres:5432/forseti
      FLYWAY_USER: forseti
    image: flyway/flyway:11.9.2-alpine
    networks:
      network:
    secrets:
      - source: {{ __db_password__ }}
        target: db_password
    volumes:
      - type: bind
        source: {{ __volumes_path__ }}/migrations
        target: /flyway/sql

  minio:
    command: server /data
    deploy:
      mode: replicated
      replicas: 1
      resources:
        limits:
          cpus: {{ minio.cpus }}
          memory: {{ minio.memory_limit }}
        reservations:
          cpus: {{ minio.cpus_reservation }}
          memory: {{ minio.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
      update_config:
        order: start-first
    environment:
      MINIO_ROOT_USER: forseti
      MINIO_ROOT_PASSWORD_FILE: /run/secrets/minio_password
      MINIO_PROMETHEUS_AUTH_TYPE: public
    healthcheck:
      test:
        - "CMD-SHELL"
        - "curl -f http://localhost:9000/minio/health/live || exit 1"
      timeout: 5s
      interval: 15s
      retries: 5
      start_period: 5s
    image: minio/minio:RELEASE.2025-09-07T16-13-09Z
    networks:
      network:
    secrets:
      - source: {{ __minio_password__ }}
        target: minio_password
    volumes:
      - type: volume
        source: minio_data
        target: /data
        volume: {}

  minio-init:
    deploy:
      labels:
        - type=job
      mode: replicated
      replicas: 1
      resources:
        limits:
          cpus: {{ minio_init.cpus }}
          memory: {{ minio_init.memory_limit }}
        reservations:
          cpus: {{ minio_init.cpus_reservation }}
          memory: {{ minio_init.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
    entrypoint: |
      sh -c '
        echo "Waiting for MinIO to be ready...";
        until mc alias set minio http://minio:9000 forseti $$(cat /run/secrets/minio_password) 2>/dev/null; do
          echo "MinIO not ready yet, retrying in 5 seconds...";
          sleep 5;
        done;
        echo "MinIO is ready, creating buckets...";
        mc mb minio/forseti --ignore-existing;
        mc mb minio/forseti-loki --ignore-existing;
        mc mb minio/forseti-tempo --ignore-existing;
        echo "MinIO buckets initialized successfully";
      '
    image: minio/minio:RELEASE.2025-09-07T16-13-09Z
    networks:
      network:
    secrets:
      - source: {{ __minio_password__ }}
        target: minio_password

  node-exporter:
    command:
      - "--path.procfs=/host/proc"
      - "--path.sysfs=/host/sys"
      - "--path.rootfs=/rootfs"
      - "--collector.filesystem.mount-points-exclude=^/(dev|proc|sys|var/lib/docker/.+|var/run/docker.sock|run/user)($$|/)"
    deploy:
      mode: global
      resources:
        limits:
          cpus: {{ node_exporter.cpus }}
          memory: {{ node_exporter.memory_limit }}
        reservations:
          cpus: {{ node_exporter.cpus_reservation }}
          memory: {{ node_exporter.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
    healthcheck:
      test:
        - CMD-SHELL
        - wget --spider -q http://localhost:9100/metrics
      timeout: 5s
      interval: 15s
      retries: 5
      start_period: 10s
    image: prom/node-exporter:v1.9.1
    networks:
      network:
    volumes:
      - type: bind
        source: /proc
        target: /host/proc
        read_only: true
      - type: bind
        source: /sys
        target: /host/sys
        read_only: true
      - type: bind
        source: /
        target: /rootfs
        read_only: true

  postgres:
    deploy:
      mode: replicated
      replicas: 1
      resources:
        limits:
          cpus: {{ postgres.cpus }}
          memory: {{ postgres.memory_limit }}
        reservations:
          cpus: {{ postgres.cpus_reservation }}
          memory: {{ postgres.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
      update_config:
        order: start-first
    environment:
      POSTGRES_USER: forseti
      POSTGRES_PASSWORD_FILE: /run/secrets/db_password
      POSTGRES_DB: forseti
    healthcheck:
      test:
        - "CMD-SHELL"
        - "pg_isready -U forseti -d forseti"
      timeout: 5s
      interval: 15s
      retries: 5
      start_period: 10s
    image: postgres:17.5-alpine
    networks:
      network:
    secrets:
      - source: {{ __db_password__ }}
        target: db_password
    volumes:
      - type: volume
        source: postgres_data
        target: /var/lib/postgresql/data
        volume: {}

  postgres-exporter:
    deploy:
      mode: replicated
      replicas: 1
      resources:
        limits:
          cpus: {{ postgres_exporter.cpus }}
          memory: {{ postgres_exporter.memory_limit }}
        reservations:
          cpus: {{ postgres_exporter.cpus_reservation }}
          memory: {{ postgres_exporter.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
    environment:
      DATA_SOURCE_URI: postgres:5432/forseti?sslmode=disable
      DATA_SOURCE_USER: forseti
      DATA_SOURCE_PASS_FILE: /run/secrets/db_password
    healthcheck:
      test:
        - CMD-SHELL
        - wget --spider -q http://localhost:9187/metrics
      timeout: 5s
      interval: 15s
      retries: 5
      start_period: 10s
    image: prometheuscommunity/postgres-exporter:v0.17.1
    networks:
      network:
    secrets:
      - source: {{ __db_password__ }}
        target: db_password

  prometheus:
    command:
      - --config.file=/etc/prometheus/prometheus.yaml
      - --storage.tsdb.path=/prometheus
      - --web.enable-remote-write-receiver
    deploy:
      labels:
        - traefik.enable=true
        - traefik.http.middlewares.prometheus-ratelimit.ratelimit.average={{ prometheus.ratelimit_average }}
        - traefik.http.middlewares.prometheus-ratelimit.ratelimit.burst={{ prometheus.ratelimit_burst }}
        - traefik.http.routers.prometheus.rule=Host(`prometheus.{{ global.domain }}`)
        {% if global.tls == "true" %}
        - traefik.http.routers.prometheus.entrypoints=websecure
        - traefik.http.routers.prometheus.tls=true
        {% else %}
        - traefik.http.routers.prometheus.entrypoints=web
        - traefik.http.routers.prometheus.tls=false
        {% endif %}
        - traefik.http.routers.prometheus.middlewares=prometheus-ratelimit
        - traefik.http.services.prometheus.loadbalancer.server.port=9090
      mode: replicated
      replicas: 1
      resources:
        limits:
          cpus: {{ prometheus.cpus }}
          memory: {{ prometheus.memory_limit }}
        reservations:
          cpus: {{ prometheus.cpus_reservation }}
          memory: {{ prometheus.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
    healthcheck:
      test:
        - CMD-SHELL
        - wget --spider -q http://localhost:9090/-/healthy
      timeout: 5s
      interval: 15s
      retries: 5
      start_period: 10s
    image: prom/prometheus:v3.4.1
    networks:
      network:
    volumes:
      - type: bind
        source: {{ __volumes_path__ }}/prometheus/config.yaml
        target: /etc/prometheus/prometheus.yaml
        read_only: true
      - type: volume
        source: prometheus_data
        target: /prometheus
        volume: {}

  rabbitmq:
    deploy:
      mode: replicated
      replicas: 1
      resources:
        limits:
          cpus: {{ rabbitmq.cpus }}
          memory: {{ rabbitmq.memory_limit }}
        reservations:
          cpus: {{ rabbitmq.cpus_reservation }}
          memory: {{ rabbitmq.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
      update_config:
        order: start-first
    entrypoint: /entrypoint.sh
    environment:
      RABBITMQ_USER: forseti
      RABBITMQ_PASSWORD_FILE: /run/secrets/rabbitmq_password
      RABBITMQ_ENABLED_PLUGINS: "rabbitmq_management,rabbitmq_prometheus"
    healthcheck:
      test:
        - "CMD"
        - "rabbitmq-diagnostics"
        - "check_port_connectivity"
      timeout: 5s
      interval: 15s
      retries: 5
      start_period: 5s
    image: rabbitmq:4.1.4-management-alpine
    networks:
      network:
    secrets:
      - source: {{ __rabbitmq_password__ }}
        target: rabbitmq_password
    volumes:
      - type: volume
        source: rabbitmq_data
        target: /var/lib/rabbitmq
        volume: {}
      - type: bind
        source: {{ __volumes_path__ }}/rabbitmq/entrypoint.sh
        target: /entrypoint.sh
        read_only: true
      - type: bind
        source: {{ __volumes_path__ }}/rabbitmq/rabbitmq.conf
        target: /etc/rabbitmq/rabbitmq.conf
        read_only: true
      - type: bind
        source: {{ __volumes_path__ }}/rabbitmq/definitions.template.json
        target: /etc/rabbitmq/definitions.template.json
        read_only: true

  redis:    
    command: >
      sh -c "redis-server --requirepass $$(cat /run/secrets/redis_password) --maxmemory {{ redis.maxmemory }} --maxmemory-policy allkeys-lru"
    deploy:
      mode: replicated
      replicas: 1
      resources:
        limits:
          cpus: {{ redis.cpus }}
          memory: {{ redis.memory_limit }}
        reservations:
          cpus: {{ redis.cpus_reservation }}
          memory: {{ redis.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
    healthcheck:
      test:
        - CMD-SHELL
        - redis-cli -a "$$(cat /run/secrets/redis_password)" ping | grep PONG || exit 1
      timeout: 5s
      interval: 15s
      retries: 5
      start_period: 10s
    image: redis:8.6.1-alpine
    networks:
      network:
    secrets:
      - source: {{ __redis_password__ }}
        target: redis_password

  redis-exporter:
    command: sh -c "export REDIS_PASSWORD=$$(cat /run/secrets/redis_password) && /redis_exporter"
    deploy:
      mode: replicated
      replicas: 1
      resources:
        limits:
          cpus: {{ redis_exporter.cpus }}
          memory: {{ redis_exporter.memory_limit }}
        reservations:
          cpus: {{ redis_exporter.cpus_reservation }}
          memory: {{ redis.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
    environment:
      REDIS_ADDR: redis://redis:6379
    healthcheck:
      test:
        - CMD
        - /redis_exporter
        - --version
      timeout: 5s
      interval: 15s
      retries: 5
      start_period: 10s
    image: oliver006/redis_exporter:v1.39.0
    networks:
      network:
    secrets:
      - source: {{ __redis_password__ }}
        target: redis_password

  tempo:
    entrypoint: sh /entrypoint.sh
    environment:
      MINIO_ACCESS_KEY: forseti
      MINIO_SECRET_KEY_FILE: /run/secrets/minio_password
      MINIO_BUCKET: forseti-tempo
    deploy:
      mode: replicated
      replicas: 1
      resources:
        limits:
          cpus: {{ tempo.cpus }}
          memory: {{ tempo.memory_limit }}
        reservations:
          cpus: {{ tempo.cpus_reservation }}
          memory: {{ tempo.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
    healthcheck:
      test:
        - CMD
        - wget
        - --spider
        - -q
        - http://localhost:3200/ready
      timeout: 5s
      interval: 15s
      retries: 20
      start_period: 10s
    image: grafana/tempo:2.9.0
    networks:
      network:
    volumes:
      - type: bind
        source: {{ __volumes_path__ }}/tempo/entrypoint.sh
        target: /entrypoint.sh
        read_only: true
      - type: bind
        source: {{ __volumes_path__ }}/tempo/config.yaml
        target: /etc/tempo/config.yaml
        read_only: true
      - type: volume
        source: tempo_data
        target: /var/tempo
        volume: {}
    secrets:
      - source: {{ __minio_password__ }}
        target: minio_password

  traefik:
    command:
      - "--entrypoints.web.address=:80"
      {% if global.tls == "true" %}
      - "--entrypoints.web.http.redirections.entryPoint.to=websecure"
      - "--entrypoints.web.http.redirections.entryPoint.scheme=https"
      - "--entrypoints.web.http.redirections.entryPoint.permanent=true"
      - "--entrypoints.websecure.address=:443"
      - "--entrypoints.websecure.http.tls=true"
      - "--providers.file.filename=/dynamic/tls.yaml"
      {% endif %}
      - "--entrypoints.postgres.address=:5432"
      - "--providers.swarm.endpoint=unix:///var/run/docker.sock"
      - "--providers.swarm.watch=true"
      - "--providers.swarm.exposedByDefault=false"
      - "--providers.swarm.network=forseti_network"
      - "--api.dashboard=true"
      - "--api.insecure=true"
      - "--log.level=INFO"
      - "--accesslog=true"
      - "--metrics.prometheus=true"
      - "--tracing.serviceName=traefik"
      - "--tracing.otlp.grpc.endpoint=alloy:4317"
      - "--tracing.otlp.grpc.insecure=true"
    deploy:
      mode: replicated
      replicas: 1
      placement:
        constraints:
          - node.role == manager
      resources:
        limits:
          cpus: {{ traefik.cpus }}
          memory: {{ traefik.memory_limit }}
        reservations:
          cpus: {{ traefik.cpus_reservation }}
          memory: {{ traefik.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
      update_config:
        order: start-first
    healthcheck:
      test:
        - CMD-SHELL
        - traefik version
      timeout: 5s
      interval: 15s
      retries: 5
      start_period: 10s
    image: traefik:v3.5.2
    networks:
      network:
    ports:
      - target: 80
        published: 80
        protocol: tcp
        mode: host
      - target: 443
        published: 443
        protocol: tcp
        mode: host
      - target: 5432
        published: 5432
        protocol: tcp
        mode: host
    volumes:
      - type: bind
        source: /var/run/docker.sock
        target: /var/run/docker.sock
        read_only: true
      {% if global.tls == "true" %}
      - type: bind
        source: {{ __volumes_path__ }}/traefik/dynamic/tls.yaml
        target: /dynamic/tls.yaml
        read_only: true
      - type: bind
        source: {{ __certs_path__ }}
        target: /certs
        read_only: true
      {% endif %}

  webapp:
    deploy:
      labels:
        - traefik.enable=true
        - traefik.http.middlewares.webapp-ratelimit.ratelimit.average={{ webapp.ratelimit_average }}
        - traefik.http.middlewares.webapp-ratelimit.ratelimit.burst={{ webapp.ratelimit_burst }}
        - traefik.http.routers.webapp.rule=Host(`{{ global.domain }}`)
        {% if global.tls == "true" %}
        - traefik.http.routers.webapp.entrypoints=websecure
        - traefik.http.routers.webapp.tls=true
        {% else %}
        - traefik.http.routers.webapp.entrypoints=web
        - traefik.http.routers.webapp.tls=false
        {% endif %}
        - traefik.http.routers.webapp.middlewares=webapp-ratelimit
        - traefik.http.services.webapp.loadbalancer.server.port=3000
      mode: replicated
      replicas: {{ webapp.replicas }}
      resources:
        limits:
          cpus: {{ webapp.cpus }}
          memory: {{ webapp.memory_limit }}
        reservations:
          cpus: {{ webapp.cpus_reservation }}
          memory: {{ webapp.memory_reservation }}
      restart_policy:
        condition: on-failure
        delay: 5s
      update_config:
        order: start-first
    environment:
      ALLOY_PUBLIC_URL: https://alloy.{{ global.domain }}
      API_INTERNAL_URL: http://api:8080
      API_PUBLIC_URL: https://api.{{ global.domain }}
      APP_ENV: production
      LOCALE: {{ webapp.locale }}
      VERSION: {{ __version__ }}
      WS_PUBLIC_URL: wss://ws.{{ global.domain }}
    healthcheck:
      test:
        - CMD-SHELL
        - curl -f http://localhost:3000
      timeout: 10s
      interval: 30s
      retries: 5
      start_period: 60s
    image: leonfoliveira/forseti-webapp:{{ __version__ }}
    networks:
      network:

volumes:
  grafana_data:
  loki_data:
  minio_data:
  postgres_data:
  prometheus_data:
  rabbitmq_data:
  tempo_data:
